# ArchiveBox Environment Variables

# Connection
ARCHIVEBOX_BASE_URL=http://localhost:8000

# Authentication (choose one method)
# Method 1: API Key
ARCHIVEBOX_API_KEY=

# Method 2: Bearer Token
ARCHIVEBOX_TOKEN=

# Method 3: Username/Password (auto-fetches token)
ARCHIVEBOX_USERNAME=
ARCHIVEBOX_PASSWORD=

# SSL Verification
ARCHIVEBOX_SSL_VERIFY=False

# MCP Server Configuration
HOST=0.0.0.0
PORT=9604
TRANSPORT=stdio

# Debug
DEBUG=False
PYTHONUNBUFFERED=1
